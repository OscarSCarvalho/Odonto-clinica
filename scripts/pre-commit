#!/usr/bin/env bash
# Git pre-commit hook — roda lint antes de cada commit.
# Instalado por: scripts/install_hooks.sh

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "🔍  Verificando código antes do commit..."

# ── Flake8 ──────────────────────────────────────────────────────────────────
if command -v flake8 &>/dev/null; then
  if flake8 app/ --max-line-length=120 --exclude=__pycache__; then
    echo -e "${GREEN}✔  Lint OK${NC}"
  else
    echo ""
    echo -e "${RED}✘  Lint falhou — corrija os erros acima antes de commitar.${NC}"
    echo -e "${YELLOW}   Dica: rode  flake8 app/ --max-line-length=120 --exclude=__pycache__${NC}"
    echo ""
    exit 1
  fi
else
  echo -e "${YELLOW}⚠  flake8 não encontrado, pulando lint.${NC}"
  echo    "   Instale com: pip install flake8"
fi

echo -e "${GREEN}✔  Commit liberado.${NC}"
echo ""
exit 0
